{
  "rewrites": [
    {
      "source": "/((?!api|_next/static|_next/image|favicon.ico|.*\\.).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/news",
      "destination": "/index.html",
      "permanent": false
    },
    {
      "source": "/article/:id",
      "destination": "/index.html",
      "permanent": false
    },
    {
      "source": "/404",
      "destination": "/index.html",
      "permanent": false
    },
    {
      "source": "/not-found",
      "destination": "/index.html",
      "permanent": false
    },
    {
      "source": "/error",
      "destination": "/index.html",
      "permanent": false
    },
    {
      "source": "/500",
      "destination": "/index.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
} 